class Solution {
public:
    bool canConstruct(string ransomNote, string magazine) {
        int cnt_char[26] = {0};
        for(char x : ransomNote){
            cnt_char[x - 'a']++;
        }
        for(char x : magazine){
            cnt_char[x - 'a']--;
        }
        for(int i = 0;i<26;i++){
            if(cnt_char[i] > 0) return false;
        }
        return true;
    }
};

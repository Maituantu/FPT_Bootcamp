class Solution {
public:
    void sortColors(vector<int>& nums) {
        int color[3] = {0};

        for(auto x : nums){
            color[x]++;
        }

        int idx = 0;
        for(int i = 0; i < 3; i++){
            while(color[i]--){
                nums[idx++] = i;
            }
        }
    }
};

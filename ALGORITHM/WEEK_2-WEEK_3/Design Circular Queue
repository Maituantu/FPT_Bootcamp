class MyCircularQueue {
    private:
    vector<int> q;
    int front;
    int size;
    int full;
public:

    MyCircularQueue(int k) {
        q.resize(k);
        front = 0;
        size = 0;
        full = k;
    }
    
    bool enQueue(int value) {
        if(isFull()) return false;
        int pos = (front + size) %full;
        q[pos] = value;
        size ++;
        return true;
    }
    
    bool deQueue() {
        if(isEmpty()) return false;
        front = (front + 1) % full;
        size--;
        return true;
    }
    
    int Front() {
        if(isEmpty()) return -1;
        return q[front];
    }
    
    int Rear() {
        if(isEmpty()) return -1;
        int rear = (front + size - 1)%full;
        return q[rear];
    }
    
    bool isEmpty() {
        return size == 0;
    }
    
    bool isFull() {
        return size == full;
    }
};

